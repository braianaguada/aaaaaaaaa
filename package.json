{
  "name": "rpg-online-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @rpg/api prisma:generate",
    "db:migrate": "pnpm --filter @rpg/api prisma:migrate",
    "db:seed": "pnpm --filter @rpg/api prisma:seed"
  }
}
